{
  "name": "callmemaybe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agentic cold-calling web agency: discover leads, call them, sell websites, build them live.",
  "scripts": {
    "dev": "node scripts/dev.js",
    "server": "node server/index.js",
    "demo:e2e": "node scripts/demo-e2e.js",
    "drill:reliability": "node scripts/reliability-drill.js",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "check": "find server scripts -name '*.js' -not -path '*/node_modules/*' -print0 | xargs -0 -n1 node --check",
    "check:revenue": "node scripts/revenue-check.js",
    "check:sponsors": "node scripts/sponsor-acceptance.js",
    "check:production": "node scripts/production-readiness-check.js",
    "check:safety": "node scripts/safety-check.js",
    "check:supermemory": "node scripts/supermemory-check.js",
    "check:moss": "node scripts/moss-check.js",
    "check:presence": "node scripts/presence-scoring-check.js",
    "check:browser-research": "node scripts/browser-research-check.js",
    "check:dedupe": "node scripts/dedupe-check.js",
    "check:autonomy": "node scripts/autonomy-check.js",
    "check:reasoning": "node scripts/reasoning-check.js",
    "check:fulfillment": "node scripts/fulfillment-check.js",
    "check:builder-hooks": "node scripts/builder-hooks-check.js",
    "check:growth": "node scripts/growth-check.js",
    "check:browser-console": "node scripts/browser-console-check.js",
    "smoke:providers": "node scripts/provider-smoke.js"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@moss-dev/moss": "^1.0.2",
    "@stripe/agent-toolkit": "^0.7.0",
    "@vitejs/plugin-react": "^4.3.4",
    "agentmail": "^0.0.51",
    "agentphone": "^1.0.10",
    "better-sqlite3": "^11.7.0",
    "browser-use-sdk": "^3.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^17.5.0",
    "supermemory": "^3.0.0",
    "svix": "^1.93.0",
    "vite": "^6.0.7",
    "zod": "^3.24.1"
  }
}
