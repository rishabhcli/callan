# callmemaybe local environment template.
# Copy to `.env`, fill values, do not commit `.env`.
# Base URLs below match the verified stack in upgrade.md §2 (May 2026).

# ---- Hackathon context ----
HACKATHON_NAME="Call My Agent Hackathon"
HACKATHON_DATE=2026-05-17
HACKATHON_LOCATION="Y Combinator, San Francisco"
HACKATHON_URL=https://events.ycombinator.com/CallMyAgentHackathon
HACKATHON_SPONSORS="Google DeepMind,AgentPhone,AgentMail,Supermemory,Moss,Browser Use,Lovable,Stripe"
STRIPE_STARTUP_BENEFITS_URL=https://stripe.com/startup-benefits/call-my-agent-hackathon

# ---- Runtime posture (default: mock; everything live-gated) ----
PORT=8787
APP_PUBLIC_URL=http://localhost:8787
DATA_DIR=.data
NODE_ENV=development
# Strong token for admin/ops mutation endpoints. Required before production_review/production_live.
ADMIN_API_TOKEN=
# RUN_MODE values:
# - mock: no provider side effects.
# - demo_live: live providers, only owned/seeded targets in ALLOWED_TARGET_*.
# - autonomous_live: discovery can enqueue outbound outreach, still compliance-gated.
# - production_review: verify production credentials/webhooks with live side effects disabled.
# - production_live: full operation; requires PRODUCTION_LIVE_ACK plus all readiness gates.
RUN_MODE=mock
PRODUCTION_LIVE_ACK=
LIVE_CALLS=false
LIVE_EMAILS=false
LIVE_PAYMENTS=false
LIVE_BROWSER_SESSIONS=false
LIVE_PUBLIC_OUTREACH=false
LIVE_BUILDS=false
# Autonomous outreach loop controls.
AUTONOMOUS_OUTREACH_ENABLED=false
OUTREACH_INTERVAL_MS=15000
# Number of concurrent caller agents draining queued outreach.
OUTREACH_BATCH_SIZE=3
MAX_ATTEMPTS_PER_PHONE=1
QUIET_HOURS_START=20
QUIET_HOURS_END=9
OUTREACH_TIMEZONE=America/Los_Angeles
# Account-manager aftercare loop: enabled by default, dry-run by default.
# It persists tasks/previews after customer launch approval. Real sends also
# need ACCOUNT_MANAGER_LIVE_SENDS=true, LIVE_EMAILS=true, AgentMail credentials,
# run-mode allow-list, quiet-window/frequency gates, and operator approval.
ACCOUNT_MANAGER_ENABLED=true
ACCOUNT_MANAGER_LIVE_SENDS=false
ACCOUNT_MANAGER_INTERVAL_MS=60000
ACCOUNT_MANAGER_FREQUENCY_CAP_HOURS=120
ACCOUNT_MANAGER_PREVIEW_CAP_HOURS=6
ACCOUNT_MANAGER_TIMEZONE=America/Los_Angeles
# Comma-separated E.164 numbers (+15555550100) the operator owns and consents to call.
ALLOWED_TARGET_PHONES=
ALLOWED_TARGET_EMAILS=
# Safe-to-sell self-check: enqueued on boot, then periodically through the durable job ledger.
SAFE_TO_SELL_SELF_CHECK_ENABLED=true
SAFE_TO_SELL_SELF_CHECK_INTERVAL_MS=86400000
# SQLite backups: enqueued on boot, then every 12h so the 24h freshness gate stays green.
OPS_BACKUP_ENABLED=true
OPS_BACKUP_INTERVAL_MS=43200000
# Reputation auto-throttle: max outbound attempts per US area code per 24h.
# When exceeded, the per-call gate blocks new dials to that area code and the
# loop emits a reputation.alert SSE event. See server/reputation.js.
REPUTATION_AREA_CODE_DAILY_LIMIT=40

# ---- Gemini (the brain) ----
# Current flagship per upgrade.md §2.8: gemini-3.1-pro-preview. Knowledge cutoff Jan 2025. SDK: @google/genai.
GEMINI_API_KEY=
GEMINI_PROJECT_NAME=
GEMINI_PROJECT_NUMBER=
GEMINI_MODEL_PRO=gemini-3.1-pro-preview
GEMINI_MODEL_FLASH=gemini-3-flash-preview

# ---- Supermemory (per-customer memory) ----
# Base host: https://api.supermemory.ai  (SDK appends /v3/* — do NOT add /v3 here, or the path doubles).
SUPERMEMORY_API_KEY=

# ---- AgentPhone (outbound voice) ----
# Base: https://api.agentphone.ai/v1  (.ai, not .to).
AGENTPHONE_API_KEY=
AGENTPHONE_BASE_URL=https://api.agentphone.ai/v1
# Leave empty on first boot — server will create the agent and log its id; paste it back here to skip recreation.
AGENTPHONE_AGENT_ID=
AGENTPHONE_DEFAULT_VOICE=Polly.Joanna
# HMAC-SHA256 shared secret used to verify inbound /api/webhooks/agentphone.
# AgentPhone signs {X-Webhook-Timestamp}.{raw_body}, requires a 5 minute replay window,
# and sends X-Webhook-ID for idempotency.
AGENTPHONE_WEBHOOK_SECRET=
AGENTPHONE_FROM_NUMBER=
# E.164 number of the live human operator to warm-transfer to when the LLM
# detects high human-intent ("speak to a manager", "transfer me") or a strong
# objection it can't handle. Empty disables transfer (server emits
# caller.transfer_unavailable instead of calling AgentPhone).
OPERATOR_TRANSFER_NUMBER=

# ---- Moss (sub-10ms in-call retrieval) ----
# Base: https://service.usemoss.dev/v1 — sub-10ms in-call retrieval only. NOT a research/search layer.
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_BASE_URL=https://service.usemoss.dev/v1

# ---- Browser Use (scraping + driving Lovable) ----
# Base: https://api.browser-use.com/api/v3 ; SDK header X-Browser-Use-API-Key.
BROWSER_USE_API_KEY=
BROWSER_USE_BASE_URL=https://api.browser-use.com/api/v3

# ---- v0 (optional website build target) ----
# Platform API key. Used only when BUILD_TARGET=v0/FULFILLMENT_TARGET=v0 and LIVE_BUILDS=true.
V0_API_KEY=
V0_BASE_URL=https://api.v0.dev
V0_MODEL_ID=v0-max
BUILD_TARGET=lovable

# ---- AgentMail (follow-up email + ICS handoff) ----
# Object model: Organization > Inbox > Thread > Message. Inbound: webhook or WebSocket (WS local, webhook in deploy).
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=
AGENTMAIL_DISPLAY_NAME=callmemaybe
AGENTMAIL_WEBHOOK_SECRET=

# ---- Stripe (hosted invoices) ----
# Use a RESTRICTED test key (rk_test_...) per upgrade.md §2.6. sk_test_ also works but rk_test_ is preferred.
# NEVER use sk_live_/rk_live_ for the hackathon demo — safety-check.js will refuse.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_USD_CENTS=50000
STRIPE_PRODUCT_NAME="Website by callmemaybe"
STRIPE_SUCCESS_URL=http://localhost:8787/success
STRIPE_CANCEL_URL=http://localhost:8787/cancel
# Recurring $29/mo hosting + 30 min of edits price (Stripe Dashboard > Products > pricing tab).
STRIPE_PRICE_ID_HOSTING=price_REPLACE_ME

# ---- Customer-business commerce (never Callan's own invoice) ----
# These gates are for the customer's products/services/menus/deposits/memberships.
# Callan's $500 website invoice still uses server/paymentFlow.js and STRIPE_* above.
CUSTOMER_COMMERCE_SANDBOX_LINKS=false
CUSTOMER_COMMERCE_LIVE_STRIPE_LINKS=false
CUSTOMER_COMMERCE_STRIPE_ACCOUNT_ID=

# ---- Provider smoke toggles (default dry-run/config checks) ----
SMOKE_GEMINI=false
SMOKE_SUPERMEMORY_WRITE=false
SMOKE_MOSS_INDEX=false
SMOKE_LIVE_CALL=false
SMOKE_AGENTMAIL_SEND=false
SMOKE_STRIPE_INVOICE=false
SMOKE_STRIPE_PRICE_CENTS=100
SMOKE_BROWSER_USE=false
SMOKE_LOVABLE_NAVIGATION=false
SMOKE_TEST_PHONE=
SMOKE_TEST_EMAIL=

# ---- Ops self-check schedulers ----
OPS_PROVIDER_POSTURE_ENABLED=true
OPS_PROVIDER_POSTURE_INTERVAL_MS=21600000
OPS_RECOVERY_ENABLED=true
OPS_RECOVERY_INTERVAL_MS=300000
OPS_RECOVERY_MAX_CALL_AGE_MS=2700000
OPS_RECOVERY_MAX_SCHEDULED_CALL_AGE_MS=60000
OPS_RECOVERY_MAX_BUILD_AGE_MS=600000
# Safe-to-sell economics guard. Blocks production if daily spend/loss exceeds
# the operator's risk budget, or if paid work is below the margin floor.
OPS_MAX_DAILY_COST_USD=25
OPS_MAX_DAILY_LOSS_USD=25
OPS_MIN_MARGIN_PCT=20
# Provider health SLO guard for the last 24h of smoke/posture events.
OPS_PROVIDER_MAX_ISSUE_RATE_PCT=20
OPS_PROVIDER_MIN_EVENTS_FOR_ISSUE_RATE=3
OPS_PROVIDER_MAX_AVG_LATENCY_MS=15000
# Worker/job health SLO guard for the last 24h of durable work.
OPS_WORKER_MAX_FAILURES_24H=3
OPS_WORKER_MAX_FAILURE_RATE_PCT=25
OPS_WORKER_MIN_RUNS_FOR_FAILURE_RATE=4
OPS_JOB_MAX_ISSUES_24H=5
