# callmemaybe local environment template.
# Copy to `.env`, fill values, do not commit `.env`.
# Base URLs below match the verified stack in upgrade.md §2 (May 2026).

# ---- Hackathon context ----
HACKATHON_NAME="Call My Agent Hackathon"
HACKATHON_DATE=2026-05-17
HACKATHON_LOCATION="Y Combinator, San Francisco"
HACKATHON_URL=https://events.ycombinator.com/CallMyAgentHackathon
HACKATHON_SPONSORS="Google DeepMind,AgentPhone,AgentMail,Supermemory,Moss,Browser Use,Lovable,Stripe"
STRIPE_STARTUP_BENEFITS_URL=https://stripe.com/startup-benefits/call-my-agent-hackathon

# ---- Runtime posture (default: mock; everything live-gated) ----
PORT=8787
APP_PUBLIC_URL=http://localhost:8787
DATA_DIR=.data
NODE_ENV=development
# RUN_MODE values:
# - mock: no provider side effects.
# - demo_live: live providers, only owned/seeded targets in ALLOWED_TARGET_*.
# - autonomous_live: discovery can enqueue outbound outreach, still compliance-gated.
RUN_MODE=mock
LIVE_CALLS=false
LIVE_EMAILS=false
LIVE_PAYMENTS=false
LIVE_BUILDS=false
# Autonomous outreach loop controls.
AUTONOMOUS_OUTREACH_ENABLED=false
OUTREACH_INTERVAL_MS=15000
OUTREACH_BATCH_SIZE=1
MAX_ATTEMPTS_PER_PHONE=1
QUIET_HOURS_START=20
QUIET_HOURS_END=9
OUTREACH_TIMEZONE=America/Los_Angeles
# Comma-separated E.164 numbers (+15555550100) the operator owns and consents to call.
ALLOWED_TARGET_PHONES=
ALLOWED_TARGET_EMAILS=

# ---- Gemini (the brain) ----
# Current flagship per upgrade.md §2.8: gemini-3.1-pro-preview. Knowledge cutoff Jan 2025. SDK: @google/genai.
GEMINI_API_KEY=
GEMINI_PROJECT_NAME=
GEMINI_PROJECT_NUMBER=
GEMINI_MODEL_PRO=gemini-3.1-pro-preview
GEMINI_MODEL_FLASH=gemini-3-flash-preview

# ---- Supermemory (per-customer memory) ----
# Base host: https://api.supermemory.ai  (SDK appends /v3/* — do NOT add /v3 here, or the path doubles).
SUPERMEMORY_API_KEY=

# ---- AgentPhone (outbound voice) ----
# Base: https://api.agentphone.ai/v1  (.ai, not .to).
AGENTPHONE_API_KEY=
AGENTPHONE_BASE_URL=https://api.agentphone.ai/v1
# Leave empty on first boot — server will create the agent and log its id; paste it back here to skip recreation.
AGENTPHONE_AGENT_ID=
AGENTPHONE_DEFAULT_VOICE=Polly.Joanna
# HMAC-SHA256 shared secret used to verify inbound /api/webhooks/agentphone.
AGENTPHONE_WEBHOOK_SECRET=
AGENTPHONE_FROM_NUMBER=

# ---- Moss (sub-10ms in-call retrieval) ----
# Base: https://service.usemoss.dev/v1 — sub-10ms in-call retrieval only. NOT a research/search layer.
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_BASE_URL=https://service.usemoss.dev/v1

# ---- Browser Use (scraping + driving Lovable) ----
# Base: https://api.browser-use.com/api/v3 ; SDK header X-Browser-Use-API-Key.
BROWSER_USE_API_KEY=
BROWSER_USE_BASE_URL=https://api.browser-use.com/api/v3

# ---- AgentMail (follow-up email + ICS handoff) ----
# Object model: Organization > Inbox > Thread > Message. Inbound: webhook or WebSocket (WS local, webhook in deploy).
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=
AGENTMAIL_DISPLAY_NAME=callmemaybe
AGENTMAIL_WEBHOOK_SECRET=

# ---- Stripe (hosted invoices) ----
# Use a RESTRICTED test key (rk_test_...) per upgrade.md §2.6. sk_test_ also works but rk_test_ is preferred.
# NEVER use sk_live_/rk_live_ for the hackathon demo — safety-check.js will refuse.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_USD_CENTS=50000
STRIPE_PRODUCT_NAME="Website by callmemaybe"
STRIPE_SUCCESS_URL=http://localhost:8787/success
STRIPE_CANCEL_URL=http://localhost:8787/cancel

# ---- Provider smoke toggles (default dry-run/config checks) ----
SMOKE_GEMINI=false
SMOKE_SUPERMEMORY_WRITE=false
SMOKE_MOSS_INDEX=false
SMOKE_LIVE_CALL=false
SMOKE_AGENTMAIL_SEND=false
SMOKE_STRIPE_INVOICE=false
SMOKE_STRIPE_PRICE_CENTS=100
SMOKE_BROWSER_USE=false
SMOKE_TEST_PHONE=
SMOKE_TEST_EMAIL=
