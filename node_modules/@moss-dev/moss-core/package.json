{
  "name": "@moss-dev/moss-core",
  "version": "0.10.0",
  "description": "Connects JS SDK to Rust Moss-Core using N-API",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "repository": {
    "type": "git"
  },
  "license": "Proprietary",
  "keywords": [
    "napi-rs",
    "NAPI",
    "N-API",
    "Rust",
    "node-addon",
    "node-addon-api"
  ],
  "files": [
    "index.d.ts",
    "index.js",
    "*.node",
    "*.dylib",
    "LICENSE-onnxruntime"
  ],
  "napi": {
    "binaryName": "js-binding",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "x86_64-apple-darwin"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "format:rs": "cargo fmt",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.2.0",
    "@oxc-node/core": "^0.0.35",
    "typescript": "^5.9.2"
  },
  "optionalDependencies": {
    "@moss-dev/moss-core-win32-x64-msvc": "0.10.0",
    "@moss-dev/moss-core-linux-x64-gnu": "0.10.0",
    "@moss-dev/moss-core-linux-arm64-gnu": "0.10.0",
    "@moss-dev/moss-core-darwin-arm64": "0.10.0",
    "@moss-dev/moss-core-darwin-x64": "0.10.0"
  }
}